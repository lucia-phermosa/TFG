  <!-- HIPS: base_link -> HipFrame (revolute) -->
  <joint name="FL_hip" type="revolute">
    <origin xyz="0.106 -0.043864 0.011989" rpy="0 0 0"/>
    <parent link="base_link"/><child link="FL_HipFrame"/>
    <axis xyz="1 0 0"/>
