  </link>

  <!-- IMU -->
  <link name="imu_link">
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/><mass value="0.1"/><inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/></inertial>
  </link>

  <!-- ======================= JOINTS ======================= -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
  </joint>

  <!-- HIPS: base_link -> HipFrame (revolute) -->
  <joint name="Revolution_12" type="revolute">
    <origin rpy="0 0 0" xyz="3.41 -3.61 2.90722"/>
    <parent link="base_link"/><child link="FR_HipFrame"/>
    <axis xyz="1 0 0"/>
    <!-- ↑ Hip roll (ab/ad). Si quisieras hip en pitch, cambia axis a "0 1 0". -->
    <limit effort="80.0" lower="-1.57" upper="1.57" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <joint name="Revolution_3" type="revolute">
    <origin rpy="0 0 0" xyz="3.6001245 -1.83513 2.90722"/>
    <parent link="base_link"/><child link="FL_HipFrame"/>
    <axis xyz="1 0 0"/>
    <limit effort="80.0" lower="-1.57" upper="1.57" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <joint name="Revolution_9" type="revolute">
    <origin rpy="0 0 0" xyz="-0.8 -3.03 2.9"/>
