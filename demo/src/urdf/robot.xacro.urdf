<?xml version="1.0" ?>
<robot name="demo">

  <!-- ======================= FRICCIÓN / CONTACTO ======================= -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>  <!-- cambiado a true para coherencia -->
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <!-- Fricción/contacto SOLO en las colisiones de los pies (antebrazos) -->
  <gazebo reference="FL_Antebrazo::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="RL_Antebrazo::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="RR_Antebrazo::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="FR_Antebrazo::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- ======================= ros2_control (URDF) ======================= -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware><plugin>gz_ros2_control/GazeboSimSystem</plugin></hardware>
    <joint name="Revolution_1"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_2"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_3"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_4"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_5"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_6"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_7"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_8"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_9"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_10"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_11"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="Revolution_12"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
  </ros2_control>

  <!-- ======================= PLUGINS de GZ ======================= -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find demo)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100.0</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
        <initial_orientation_as_reference>true</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ======================= LINKS ======================= -->
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.132259326627842"/>
      <inertia ixx="0.000199" ixy="0.000129" ixz="2e-06" iyy="0.001133" iyz="-3e-06" izz="0.001312"/>
    </inertial>
    <visual><origin rpy="0 0 0" xyz="0 0 0"/><geometry><mesh filename="file:///home/lucia/Desktop/demo/src/meshes/base_link.stl" scale="0.02 0.02 0.02"/></geometry></visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0"/><geometry><mesh filename="file:///home/lucia/Desktop/demo/src/meshes/base_link.stl" scale="0.02 0.02 0.02"/></geometry></collision>
  </link>

  <!-- HIP FRAMES (nuevos, sin geometría) -->
  <link name="FL_HipFrame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <link name="FR_HipFrame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <link name="RL_HipFrame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>
  <link name="RR_HipFrame"><inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.001"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial></link>

