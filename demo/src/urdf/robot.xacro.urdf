<?xml version="1.0" ?>
<robot name="demo">

  <!-- ======================= FRICCIÓN / CONTACTO ======================= -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Hombro">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Brazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>  <!-- cambiado a true para coherencia -->
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FL_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RL_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="RR_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <gazebo reference="FR_Antebrazo">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.2</mu1><mu2>0.2</mu2>
    <self_collide>true</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <!-- Fricción/contacto SOLO en las colisiones de los pies (antebrazos) -->
  <gazebo reference="FL_Foot::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="RL_Foot::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="RR_Foot::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="FR_Foot::collision">
    <surface>
      <friction>
        <ode>
          <mu>1.4</mu>
          <mu2>1.2</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>2e6</kp>
          <kd>2.0</kd>
          <max_vel>0.2</max_vel>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- ======================= ros2_control (URDF) ======================= -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware><plugin>gz_ros2_control/GazeboSimSystem</plugin></hardware>
    <joint name="FR_elbow"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="FR_shoulder"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="FR_hip"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RR_elbow"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RR_shoulder"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RR_hip"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RL_elbow"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RL_shoulder"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="RL_hip"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="FL_elbow"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="FL_shoulder"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="FL_hip"><command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/><state_interface name="effort"/></joint>
  </ros2_control>

  <!-- ======================= PLUGINS de GZ ======================= -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find demo)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_sensor_pose>true</publish_sensor_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>100</static_update_frequency>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_topic>/odom</odom_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100.0</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
        <initial_orientation_as_reference>true</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

