  <!-- IMU link -->
  <link name="imu_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <!-- ===== Joints (idénticos) ===== -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>
  <joint name="Revolution_1" type="revolute">
    <origin rpy="0 0 0" xyz="-1.258 0.8 -1.435"/>
    <parent link="FL_Brazo"/>
    <child link="FL_Antebrazo"/>
    <axis xyz="0 -1 0"/>
    <limit effort="10.0" lower="-1.57" upper="1.57" velocity="5.0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>
  <joint name="Revolution_2" type="revolute">
    <origin rpy="0 0 0" xyz="-0.1155 0.415 0.025"/>
    <parent link="FL_Hombro"/>
    <child link="FL_Brazo"/>
    <axis xyz="0 -1 0"/>
    <limit effort="10.0" lower="-1.57" upper="1.57" velocity="5.0"/>
    <dynamics damping="0.01" friction="0.1"/>
